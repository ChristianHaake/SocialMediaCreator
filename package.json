{
  "name": "social-media-creator",
  "private": true,
  "version": "1.0.0",
  "description": "Educational browser workshop for creating fictional social-media simulations.",
  "license": "GPL-3.0-only",
  "homepage": "https://smc.haak3.de",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChristianHaake/SocialMediaCreator.git"
  },
  "bugs": {
    "url": "https://github.com/ChristianHaake/SocialMediaCreator/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "wrangler deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify": "npm test && npm run lint -- --max-warnings=0 && npm run build && npm run test:e2e",
    "smoke:production": "node scripts/smoke-production.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.19.21",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  }
}
